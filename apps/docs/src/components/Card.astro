---
interface Props {
  title?: string;
  description?: string;
  href?: string;
  icon?: string;
  featured?: boolean;
}

const { title, description, href, icon, featured = false } = Astro.props;
const isLink = !!href;
const Element = isLink ? 'a' : 'div';
---

<Element
  href={href}
  class:list={[
    'card block p-6 transition-all duration-200',
    isLink && 'hover:shadow-lg hover:scale-105 cursor-pointer',
    featured && 'ring-2 ring-primary-500 dark:ring-primary-400'
  ]}
>
  {icon && (
    <div class="text-4xl mb-4">
      {icon}
    </div>
  )}

  {title && (
    <h3 class="text-lg font-semibold mb-2 text-gray-900 dark:text-gray-100">
      {title}
      {isLink && (
        <svg class="inline w-4 h-4 ml-1 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      )}
    </h3>
  )}

  {description && (
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
      {description}
    </p>
  )}

  <div class="text-sm text-gray-700 dark:text-gray-300">
    <slot />
  </div>
</Element>
