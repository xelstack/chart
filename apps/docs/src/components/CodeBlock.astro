---
interface Props {
  code: string;
  lang?: string;
  title?: string;
  showLineNumbers?: boolean;
}

const { code, lang = 'typescript', title, showLineNumbers = false } = Astro.props;
const lines = code.trim().split('\n');
---

<div class="code-block-wrapper my-6">
  {title && (
    <div class="flex items-center justify-between px-4 py-2 bg-gray-800 dark:bg-gray-900 border-b border-gray-700 rounded-t-lg">
      <span class="text-sm font-medium text-gray-300">{title}</span>
      <span class="text-xs text-gray-500 uppercase">{lang}</span>
    </div>
  )}

  <div class="relative group">
    <pre class:list={[
      'overflow-x-auto p-4 bg-gray-900 dark:bg-gray-950',
      title ? '' : 'rounded-t-lg',
      'rounded-b-lg'
    ]}><code class:list={[
      `language-${lang}`,
      showLineNumbers ? 'line-numbers' : ''
    ]}>{code.trim()}</code></pre>

    <!-- Copy button -->
    <button
      class="copy-btn absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity px-3 py-1.5 bg-gray-700 hover:bg-gray-600 text-gray-200 text-xs rounded-md flex items-center space-x-1"
      data-code={code.trim()}
      aria-label="코드 복사"
    >
      <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
      </svg>
      <span class="copy-text">Copy</span>
    </button>

    <!-- Success checkmark (hidden by default) -->
    <div class="copied-indicator hidden absolute top-2 right-2 px-3 py-1.5 bg-green-600 text-white text-xs rounded-md flex items-center space-x-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      <span>Copied!</span>
    </div>
  </div>
</div>

<script>
  function setupCopyButtons() {
    const copyButtons = document.querySelectorAll('.copy-btn');

    copyButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const code = button.getAttribute('data-code');
        if (!code) return;

        try {
          await navigator.clipboard.writeText(code);

          // Hide button, show success indicator
          button.classList.add('hidden');
          const indicator = button.nextElementSibling;
          indicator?.classList.remove('hidden');

          // Reset after 2 seconds
          setTimeout(() => {
            button.classList.remove('hidden');
            indicator?.classList.add('hidden');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    });
  }

  // Run on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupCopyButtons);
  } else {
    setupCopyButtons();
  }
</script>

<style>
  .line-numbers {
    counter-reset: line;
  }

  .line-numbers code::before {
    counter-increment: line;
    content: counter(line);
    display: inline-block;
    width: 2em;
    margin-right: 1em;
    text-align: right;
    color: #6b7280;
  }
</style>
