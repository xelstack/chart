---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="페이지를 찾을 수 없습니다 - 404"
  description="요청하신 페이지를 찾을 수 없습니다. XelStack Chart 문서 사이트로 돌아가세요."
>
  <div class="min-h-screen flex items-center justify-center px-4 py-16">
    <div class="max-w-2xl w-full text-center">
      <!-- 404 Illustration -->
      <div class="mb-8">
        <svg class="w-64 h-64 mx-auto text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>

      <!-- Error Message -->
      <h1 class="text-6xl font-bold text-gray-900 dark:text-gray-100 mb-4">
        404
      </h1>

      <h2 class="text-2xl font-semibold text-gray-800 dark:text-gray-200 mb-4">
        페이지를 찾을 수 없습니다
      </h2>

      <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">
        요청하신 페이지가 존재하지 않거나 이동되었을 수 있습니다.
      </p>

      <!-- Navigation Links -->
      <div class="space-y-4">
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/"
            class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            홈으로 돌아가기
          </a>

          <a
            href="/getting-started"
            class="inline-flex items-center justify-center px-6 py-3 bg-gray-200 dark:bg-gray-800 hover:bg-gray-300 dark:hover:bg-gray-700 text-gray-900 dark:text-gray-100 font-medium rounded-lg transition-colors"
          >
            시작하기
          </a>
        </div>

        <!-- Helpful Links -->
        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">
            유용한 링크
          </h3>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-xl mx-auto">
            <a
              href="/api"
              class="p-4 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-primary-500 dark:hover:border-primary-500 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors text-left"
            >
              <div class="font-semibold text-gray-900 dark:text-gray-100 mb-1">
                API Reference
              </div>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                전체 API 문서
              </div>
            </a>

            <a
              href="/examples"
              class="p-4 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-primary-500 dark:hover:border-primary-500 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors text-left"
            >
              <div class="font-semibold text-gray-900 dark:text-gray-100 mb-1">
                예제
              </div>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                다양한 사용 예제
              </div>
            </a>

            <a
              href="/charts"
              class="p-4 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-primary-500 dark:hover:border-primary-500 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors text-left"
            >
              <div class="font-semibold text-gray-900 dark:text-gray-100 mb-1">
                차트 타입
              </div>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                지원하는 차트 종류
              </div>
            </a>

            <a
              href="/playground"
              class="p-4 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-primary-500 dark:hover:border-primary-500 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors text-left"
            >
              <div class="font-semibold text-gray-900 dark:text-gray-100 mb-1">
                Playground
              </div>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                직접 실험해보기
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
