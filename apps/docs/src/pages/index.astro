---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="XelStack Chart - 고성능 함수형 차트 라이브러리">
  <div class="min-h-screen">
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900">
      <div class="container mx-auto px-4 py-20 sm:py-32">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight mb-6">
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-accent-600">
              XelStack Chart
            </span>
          </h1>
          <p class="text-xl sm:text-2xl text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
            함수형 프로그래밍 패러다임으로 구축된<br />
            고성능, 타입 안전한 차트 라이브러리
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="/getting-started" class="btn btn-primary px-8 py-3 text-lg">
              시작하기 →
            </a>
            <a href="/examples" class="btn btn-secondary px-8 py-3 text-lg">
              예제 보기
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-20 bg-white dark:bg-gray-800">
      <div class="container mx-auto px-4">
        <h2 class="text-4xl font-bold text-center mb-12">주요 기능</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="card p-6">
            <div class="text-4xl mb-4">⚡</div>
            <h3 class="text-xl font-semibold mb-2">고성능</h3>
            <p class="text-gray-600 dark:text-gray-300">
              10,000개 이상의 데이터 포인트도 부드럽게 처리
            </p>
          </div>

          <div class="card p-6">
            <div class="text-4xl mb-4">🔧</div>
            <h3 class="text-xl font-semibold mb-2">함수형 API</h3>
            <p class="text-gray-600 dark:text-gray-300">
              순수 함수와 불변성으로 예측 가능한 동작
            </p>
          </div>

          <div class="card p-6">
            <div class="text-4xl mb-4">📐</div>
            <h3 class="text-xl font-semibold mb-2">TypeScript</h3>
            <p class="text-gray-600 dark:text-gray-300">
              완벽한 타입 안전성과 자동 완성 지원
            </p>
          </div>

          <div class="card p-6">
            <div class="text-4xl mb-4">🎨</div>
            <h3 class="text-xl font-semibold mb-2">커스터마이징</h3>
            <p class="text-gray-600 dark:text-gray-300">
              유연한 설정으로 원하는 스타일 구현
            </p>
          </div>

          <div class="card p-6">
            <div class="text-4xl mb-4">📦</div>
            <h3 class="text-xl font-semibold mb-2">경량</h3>
            <p class="text-gray-600 dark:text-gray-300">
              53KB (ESM) 작은 번들 크기
            </p>
          </div>

          <div class="card p-6">
            <div class="text-4xl mb-4">🔄</div>
            <h3 class="text-xl font-semibold mb-2">실시간</h3>
            <p class="text-gray-600 dark:text-gray-300">
              실시간 데이터 업데이트 지원
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Start Section -->
    <section class="py-20 bg-gray-50 dark:bg-gray-900">
      <div class="container mx-auto px-4">
        <h2 class="text-4xl font-bold text-center mb-12">빠른 시작</h2>
        <div class="max-w-3xl mx-auto">
          <div class="bg-gray-900 rounded-lg p-6 overflow-x-auto">
            <pre class="text-gray-100 text-sm"><code>{`// 1. 설치
npm install @xelstack/chart-core

// 2. 차트 생성
import { createChart } from '@xelstack/chart-core';

const chart = createChart(container, dataset, {
  type: 'line',
  title: '내 첫 차트'
});

// 3. 데이터 업데이트
chart.updateData(newDataset);
chart.render();`}</code></pre>
          </div>
          <div class="text-center mt-8">
            <a href="/getting-started" class="text-primary-600 dark:text-primary-400 font-semibold hover:underline">
              자세한 가이드 보기 →
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
