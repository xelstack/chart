---
import BaseLayout from '../layouts/BaseLayout.astro';
import Playground from '../components/Playground.tsx';

const title = 'Playground - XelStack Chart';
const description = '실시간으로 차트 코드를 작성하고 결과를 확인하세요';

// 초기 코드
const initialCode = `// 데이터셋 생성
const dataset = {
  points: [
    { x: 0, y: 10 },
    { x: 1, y: 20 },
    { x: 2, y: 15 },
    { x: 3, y: 25 },
    { x: 4, y: 22 },
    { x: 5, y: 30 },
  ],
};

// 차트 생성
createChart(container, dataset, {
  type: 'line',
  title: '내 첫 번째 차트',
  width: 800,
  height: 600,
  colors: ['#3366ff'],
  showGrid: true,
});`;
---

<BaseLayout title={title} description={description}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <!-- 헤더 -->
    <header class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 sticky top-0 z-10">
      <div class="container mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
              Playground
            </h1>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
              실시간으로 차트 코드를 작성하고 결과를 확인하세요
            </p>
          </div>

          <div class="flex items-center gap-4">
            <a
              href="/getting-started"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400"
            >
              시작하기
            </a>
            <a
              href="/api"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400"
            >
              API 문서
            </a>
            <a
              href="/examples"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400"
            >
              예제
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- 메인 컨텐츠 -->
    <main class="container mx-auto px-4 py-8">
      <div class="max-w-7xl mx-auto">
        <!-- 안내 메시지 -->
        <div class="mb-6 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-blue-600 dark:text-blue-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <h3 class="text-sm font-semibold text-blue-900 dark:text-blue-100 mb-1">
                사용 방법
              </h3>
              <ul class="text-sm text-blue-800 dark:text-blue-200 space-y-1">
                <li>• 왼쪽 에디터에서 TypeScript 코드를 작성하세요</li>
                <li>• <code class="px-1 py-0.5 bg-blue-100 dark:bg-blue-800 rounded">createChart(container, dataset, config)</code> 함수를 사용하세요</li>
                <li>• 코드는 자동으로 실행되며, 오른쪽에 결과가 표시됩니다</li>
                <li>• "공유" 버튼을 클릭하여 코드 URL을 생성할 수 있습니다</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- 플레이그라운드 -->
        <Playground
          initialCode={initialCode}
          title="라이브 에디터"
          editorHeight="500px"
          client:load
        />

        <!-- 예제 템플릿 -->
        <div class="mt-8">
          <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4">
            예제 템플릿
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <!-- Line Chart -->
            <button
              class="p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-primary-500 dark:hover:border-primary-500 transition-colors text-left"
              onclick="loadTemplate('line')"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Line Chart
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                기본 선 차트 예제
              </p>
            </button>

            <!-- Bar Chart -->
            <button
              class="p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-primary-500 dark:hover:border-primary-500 transition-colors text-left"
              onclick="loadTemplate('bar')"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Bar Chart
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                기본 막대 차트 예제
              </p>
            </button>

            <!-- Pie Chart -->
            <button
              class="p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-primary-500 dark:hover:border-primary-500 transition-colors text-left"
              onclick="loadTemplate('pie')"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Pie Chart
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                기본 파이 차트 예제
              </p>
            </button>

            <!-- Scatter Chart -->
            <button
              class="p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-primary-500 dark:hover:border-primary-500 transition-colors text-left"
              onclick="loadTemplate('scatter')"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Scatter Chart
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                기본 산점도 예제
              </p>
            </button>

            <!-- Multi-series -->
            <button
              class="p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-primary-500 dark:hover:border-primary-500 transition-colors text-left"
              onclick="loadTemplate('multi')"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Multi-Series
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                여러 데이터 시리즈
              </p>
            </button>

            <!-- Real-time -->
            <button
              class="p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-primary-500 dark:hover:border-primary-500 transition-colors text-left"
              onclick="loadTemplate('realtime')"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Real-time Update
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                실시간 데이터 업데이트
              </p>
            </button>

            <!-- Large Multi-Series -->
            <button
              class="p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-primary-500 dark:hover:border-primary-500 transition-colors text-left"
              onclick="loadTemplate('large-multiseries')"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Large Multi-Series
                <span class="ml-2 text-xs bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-2 py-1 rounded">500 series</span>
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                대용량 멀티 시리즈 (정적)
              </p>
            </button>

            <!-- Realtime Large Multi-Series -->
            <button
              class="p-4 bg-white dark:bg-gray-800 border border-primary-600 dark:border-primary-500 rounded-lg hover:border-primary-700 dark:hover:border-primary-400 transition-colors text-left ring-2 ring-primary-500/20"
              onclick="loadTemplate('realtime-large-multiseries')"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Realtime Large Multi-Series
                <span class="ml-2 text-xs bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300 px-2 py-1 rounded">LIVE</span>
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                500개 시리즈 실시간 업데이트
              </p>
            </button>
          </div>

          <!-- 증분 렌더링 (Incremental Rendering) 섹션 -->
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mt-8 mb-4 flex items-center gap-2">
            Incremental Rendering
            <span class="text-xs bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 px-2 py-1 rounded">NEW</span>
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            새로운 증분 렌더링 API를 사용한 예제입니다. 기존 방식 대비 최대 93% 성능 향상을 제공합니다.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <!-- Incremental Realtime -->
            <button
              class="p-4 bg-white dark:bg-gray-800 border border-green-500 dark:border-green-600 rounded-lg hover:border-green-600 dark:hover:border-green-500 transition-colors text-left ring-2 ring-green-500/20"
              onclick="loadTemplate('incremental-realtime')"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Incremental Realtime
                <span class="ml-2 text-xs bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 px-2 py-1 rounded">NEW</span>
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                addPointsIncremental 기본 예제
              </p>
            </button>

            <!-- Incremental Batch -->
            <button
              class="p-4 bg-white dark:bg-gray-800 border border-green-500 dark:border-green-600 rounded-lg hover:border-green-600 dark:hover:border-green-500 transition-colors text-left ring-2 ring-green-500/20"
              onclick="loadTemplate('incremental-batch')"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Incremental Batch
                <span class="ml-2 text-xs bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 px-2 py-1 rounded">NEW</span>
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                updateDataIncremental 델타 계산 예제
              </p>
            </button>

            <!-- Incremental Monitor -->
            <button
              class="p-4 bg-white dark:bg-gray-800 border border-green-500 dark:border-green-600 rounded-lg hover:border-green-600 dark:hover:border-green-500 transition-colors text-left ring-2 ring-green-500/20"
              onclick="loadTemplate('incremental-monitor')"
            >
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Incremental Monitor
                <span class="ml-2 text-xs bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 px-2 py-1 rounded">NEW</span>
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                getIncrementalState 성능 모니터링 예제
              </p>
            </button>
          </div>
        </div>
      </div>
    </main>

    <!-- 푸터 -->
    <footer class="mt-16 border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800">
      <div class="container mx-auto px-4 py-8">
        <div class="text-center text-sm text-gray-600 dark:text-gray-400">
          <p>
            더 많은 예제는 <a href="/examples" class="text-primary-600 dark:text-primary-400 hover:underline">예제 페이지</a>에서 확인하세요
          </p>
        </div>
      </div>
    </footer>
  </div>

  <script is:inline>
    // @ts-nocheck - Browser context code with DOM/Browser APIs
    // 템플릿 로드 함수 (전역 함수로 정의)
    window.loadTemplate = function(type) {
      const templates = {
        line: `// Line Chart
const dataset = {
  points: [
    { x: 0, y: 10 },
    { x: 1, y: 20 },
    { x: 2, y: 15 },
    { x: 3, y: 25 },
    { x: 4, y: 22 },
    { x: 5, y: 30 },
  ],
};

createChart(container, dataset, {
  type: 'line',
  title: 'Line Chart Example',
  width: 800,
  height: 600,
  colors: ['#3366ff'],
  showGrid: true,
});`,
        bar: `// Bar Chart
const dataset = {
  points: [
    { x: '1월', y: 100 },
    { x: '2월', y: 150 },
    { x: '3월', y: 120 },
    { x: '4월', y: 180 },
    { x: '5월', y: 200 },
  ],
};

createChart(container, dataset, {
  type: 'bar',
  title: 'Bar Chart Example',
  width: 800,
  height: 600,
  colors: ['#3366ff'],
  showGrid: true,
});`,
        pie: `// Pie Chart
const dataset = {
  points: [
    { x: 'Chrome', y: 65 },
    { x: 'Safari', y: 18 },
    { x: 'Firefox', y: 10 },
    { x: 'Edge', y: 5 },
    { x: '기타', y: 2 },
  ],
};

createChart(container, dataset, {
  type: 'pie',
  title: 'Pie Chart Example',
  width: 800,
  height: 600,
  colors: ['#3366ff', '#ff6633', '#33ff66', '#ffcc33', '#cc66ff'],
});`,
        scatter: `// Scatter Chart
const dataset = {
  points: Array.from({ length: 50 }, () => ({
    x: Math.random() * 100,
    y: Math.random() * 100,
  })),
};

createChart(container, dataset, {
  type: 'scatter',
  title: 'Scatter Chart Example',
  width: 800,
  height: 600,
  colors: ['#3366ff'],
  showGrid: true,
});`,
        multi: `// Multi-Series Chart
const dataset = {
  points: [
    // Series A
    { x: 0, y: 10, series: 'Product A' },
    { x: 1, y: 20, series: 'Product A' },
    { x: 2, y: 15, series: 'Product A' },
    { x: 3, y: 25, series: 'Product A' },
    // Series B
    { x: 0, y: 15, series: 'Product B' },
    { x: 1, y: 25, series: 'Product B' },
    { x: 2, y: 20, series: 'Product B' },
    { x: 3, y: 30, series: 'Product B' },
  ],
};

createChart(container, dataset, {
  type: 'line',
  title: 'Multi-Series Chart',
  width: 800,
  height: 600,
  colors: ['#3366ff', '#ff6633'],
  showGrid: true,
});`,
        realtime: `// Real-time Update Example
let dataset = {
  points: [{ x: 0, y: 0 }],
};

const chart = createChart(container, dataset, {
  type: 'line',
  title: 'Real-time Data (코드 실행 후 자동 업데이트)',
  width: 800,
  height: 600,
  colors: ['#3366ff'],
  showGrid: true,
});

// 1초마다 새 데이터 추가
let time = 0;
setInterval(() => {
  time++;
  const newPoint = {
    x: time,
    y: Math.sin(time / 5) * 50 + Math.random() * 10,
  };

  // 마지막 50개 포인트만 유지
  dataset.points = [...dataset.points, newPoint].slice(-50);

  chart.updateData(dataset);
  chart.render();
}, 1000);`,
        'large-multiseries': `// Large Multi-Series Chart (500 series)
// 대용량 데이터 생성 함수
function generateLargeMultiSeriesData(seriesCount, pointsPerSeries) {
  const points = [];

  for (let s = 0; s < seriesCount; s++) {
    const seriesName = \`Series \${s + 1}\`;

    for (let i = 0; i < pointsPerSeries; i++) {
      // 사인파 패턴으로 데이터 생성
      const y = Math.sin(i / 100 + s / 50) * 50 + (Math.random() - 0.5) * 10;
      points.push({ x: i, y, series: seriesName });
    }
  }

  return { points };
}

// 500개 시리즈 * 100 포인트 = 50,000 포인트
const dataset = generateLargeMultiSeriesData(500, 100);

// 성능 모니터링
const startTime = performance.now();

const chart = createChart(container, dataset, {
  type: 'line',
  title: 'Large Multi-Series Chart (500 series)',
  width: 800,
  height: 600,
  colors: ['#3366ff', '#ff6633', '#33ff66', '#ffcc33', '#cc66ff'],
  showGrid: true,
});

const renderTime = performance.now() - startTime;

// 성능 정보 표시
console.log(\`Rendered \${dataset.points.length} points in \${renderTime.toFixed(2)}ms\`);
console.log(\`Dataset size: ~\${(dataset.points.length * 68 / 1024 / 1024).toFixed(2)}MB\`);`,
        'realtime-large-multiseries': `// Realtime Large Multi-Series Chart (500 series)
// 500개 시리즈를 실시간으로 업데이트하며 렌더링

// 초기 데이터 생성 함수
function generateInitialData(seriesCount, pointsPerSeries) {
  const points = [];

  for (let s = 0; s < seriesCount; s++) {
    const seriesName = \`Series \${s + 1}\`;

    for (let i = 0; i < pointsPerSeries; i++) {
      const y = Math.sin(i / 10 + s / 50) * 50 + 50;
      points.push({ x: i, y, series: seriesName });
    }
  }

  return { points };
}

// 500개 시리즈 * 50 포인트 초기 데이터
const initialDataset = generateInitialData(500, 50);

console.log('=== Realtime Large Multi-Series Chart ===');
console.log(\`Initial dataset: 500 series * 50 points = \${initialDataset.points.length} points\`);

// 차트 생성 (realtime 모드 활성화)
const chart = createChart(container, initialDataset, {
  type: 'line',
  title: 'Realtime Large Multi-Series (500 series, auto-updating)',
  width: 800,
  height: 600,
  colors: ['#3366ff', '#ff6633', '#33ff66', '#ffcc33', '#cc66ff'],
  showGrid: true,
  realtime: {
    enabled: true,
    maxPoints: 50000, // 500 series * 100 points max
  },
});

// 성능 모니터링
let frameCount = 0;
let lastFpsUpdate = performance.now();
let fps = 0;

// 실시간 업데이트: 500개 시리즈에 동시에 새 포인트 추가
let timeStep = 50; // 현재 X 위치
const updateInterval = setInterval(() => {
  timeStep++;

  // 500개 시리즈 모두에 새 포인트 추가
  const newPoints = [];
  for (let s = 0; s < 500; s++) {
    const seriesName = \`Series \${s + 1}\`;
    const y = Math.sin(timeStep / 10 + s / 50) * 50 + 50 + (Math.random() - 0.5) * 5;
    newPoints.push({ x: timeStep, y, series: seriesName });
  }

  // addPoints로 500개 포인트 동시 추가 + 자동 렌더링 + 자동 스크롤
  const start = performance.now();
  chart.addPoints(newPoints, {
    autoRender: true,
    autoScroll: true,
  });
  const updateTime = performance.now() - start;

  // FPS 계산
  frameCount++;
  const now = performance.now();
  if (now - lastFpsUpdate >= 1000) {
    fps = Math.round((frameCount * 1000) / (now - lastFpsUpdate));
    frameCount = 0;
    lastFpsUpdate = now;

    // 성능 로그 (1초마다)
    const state = chart.getState();
    console.log(\`[t=\${timeStep}] Added 500 points in \${updateTime.toFixed(2)}ms | FPS: \${fps} | Total: \${state.pointCount} points\`);
  }

  // 30초 후 자동 중지
  if (timeStep >= 80) {
    clearInterval(updateInterval);
    console.log('Real-time updates stopped after 30 updates');
    console.log(\`Final dataset: \${chart.getState().pointCount} points\`);
  }
}, 1000); // 1초마다 500개 시리즈 업데이트 (초당 500 points)

console.log('Real-time updates started. Watch console for performance metrics...');
console.log('Updates will stop automatically after 30 seconds.');`,
        'incremental-realtime': `// Incremental Realtime - 증분 렌더링으로 실시간 업데이트
// 기존 방식 대비 93% 성능 향상

const chart = createChart(container, { points: [] }, {
  type: 'line',
  title: 'Incremental Realtime (addPointsIncremental)',
  width: 800,
  height: 600,
  colors: ['#3366ff'],
  showGrid: true,
});

// 증분 렌더링 설정 - 최대 500개 포인트 (슬라이딩 윈도우)
chart.setIncrementalOptions({ maxPoints: 500 });

console.log('=== Incremental Realtime Demo ===');
console.log('새 데이터만 렌더링하여 성능 최적화');

let time = 0;
const interval = setInterval(() => {
  time++;

  // 증분 렌더링 - 새 포인트만 렌더링
  chart.addPointsIncremental([{
    x: time,
    y: Math.sin(time / 10) * 50 + 50 + Math.random() * 10
  }]);

  // 30초 후 중지
  if (time >= 300) {
    clearInterval(interval);
    console.log('Demo stopped');
  }
}, 100);

console.log('100ms마다 1포인트 추가 (10 points/sec)');
console.log('30초 후 자동 중지');`,
        'incremental-batch': `// Incremental Batch Update - 델타 계산으로 변경분만 렌더링
// 서버에서 전체 데이터를 받아도 변경분만 처리

const chart = createChart(container, { points: [] }, {
  type: 'line',
  title: 'Incremental Batch Update (updateDataIncremental)',
  width: 800,
  height: 600,
  colors: ['#3366ff', '#ff6633'],
  showGrid: true,
});

chart.setIncrementalOptions({ maxPoints: 200 });

console.log('=== Incremental Batch Update Demo ===');
console.log('전체 데이터를 받아도 변경분만 렌더링');

// 초기 데이터
let currentData = Array.from({ length: 50 }, (_, i) => ({
  x: i,
  y: Math.sin(i / 10) * 50 + 50
}));

chart.updateDataIncremental(currentData);

// 1초마다 배치 업데이트 (10개씩 추가)
let batchCount = 0;
const interval = setInterval(() => {
  batchCount++;

  // 새 데이터 10개 추가
  const newPoints = Array.from({ length: 10 }, (_, i) => ({
    x: currentData.length + i,
    y: Math.sin((currentData.length + i) / 10) * 50 + 50 + Math.random() * 10
  }));

  currentData = [...currentData, ...newPoints];

  // 델타 자동 계산 - 추가된 10개만 렌더링
  const start = performance.now();
  chart.updateDataIncremental(currentData);
  const elapsed = performance.now() - start;

  console.log(\`Batch \${batchCount}: +10 points, delta calc: \${elapsed.toFixed(2)}ms\`);

  if (batchCount >= 15) {
    clearInterval(interval);
    console.log(\`Total: \${currentData.length} points\`);
  }
}, 1000);`,
        'incremental-monitor': `// Incremental Performance Monitor
// getIncrementalState로 실시간 성능 모니터링

const chart = createChart(container, { points: [] }, {
  type: 'line',
  title: 'Performance Monitor (getIncrementalState)',
  width: 800,
  height: 600,
  colors: ['#3366ff'],
  showGrid: true,
});

chart.setIncrementalOptions({
  maxPoints: 1000,
  frameBuffering: true
});

console.log('=== Incremental Performance Monitor ===');
console.log('실시간 성능 지표 모니터링\\n');

let time = 0;

// 고빈도 데이터 추가 (50ms = 20 points/sec)
const dataInterval = setInterval(() => {
  time++;
  chart.addPointsIncremental([{
    x: time,
    y: Math.sin(time / 20) * 50 + 50 + Math.random() * 5
  }]);

  if (time >= 600) {
    clearInterval(dataInterval);
    clearInterval(monitorInterval);
    console.log('\\n=== Final Stats ===');
    const finalState = chart.getIncrementalState();
    console.log(\`Total Points: \${finalState.totalPoints}\`);
    console.log(\`Total Frames: \${finalState.frameCount}\`);
    console.log(\`Avg Frame Time: \${finalState.averageFrameTime.toFixed(2)}ms\`);
  }
}, 50);

// 1초마다 성능 모니터링
const monitorInterval = setInterval(() => {
  const state = chart.getIncrementalState();

  const fps = state.averageFrameTime > 0
    ? Math.round(1000 / state.averageFrameTime)
    : 0;

  console.log(\`[Monitor] Points: \${state.totalPoints} | Pending: \${state.pendingPoints} | FPS: \${fps} | Paused: \${state.isPaused}\`);
}, 1000);

// 일시정지/재개 테스트 (10초에 일시정지, 15초에 재개)
setTimeout(() => {
  console.log('\\n>>> Pausing incremental rendering...');
  chart.pauseIncremental();
}, 10000);

setTimeout(() => {
  console.log('>>> Resuming incremental rendering...\\n');
  chart.resumeIncremental();
}, 15000);`,
