{
  "name": "@xelstack/chart-core",
  "version": "1.0.0",
  "description": "고성능 차트 라이브러리 핵심 패키지",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./charts/line": {
      "types": "./dist/types/charts/line.d.ts",
      "import": "./dist/esm/charts/line.js",
      "require": "./dist/cjs/charts/line.js"
    },
    "./charts/bar": {
      "types": "./dist/types/charts/bar.d.ts",
      "import": "./dist/esm/charts/bar.js",
      "require": "./dist/cjs/charts/bar.js"
    },
    "./charts/pie": {
      "types": "./dist/types/charts/pie.d.ts",
      "import": "./dist/esm/charts/pie.js",
      "require": "./dist/cjs/charts/pie.js"
    },
    "./utils/sampling": {
      "types": "./dist/types/utils/sampling.d.ts",
      "import": "./dist/esm/utils/sampling.js",
      "require": "./dist/cjs/utils/sampling.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/fix-dts-paths.mjs && rollup -c",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:perf": "playwright test -c playwright.perf.config.ts",
    "test:e2e": "playwright test",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "chart",
    "visualization",
    "canvas",
    "performance"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/jsdom": "^27.0.0",
    "jsdom": "^27.2.0",
    "rollup": "^4.27.0",
    "tsc-alias": "^1.8.16",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
