{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declarationDir": "./dist/types",
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@chart/api/*": ["src/api/*"],
      "@chart/charts/*": ["src/charts/*"],
      "@chart/effects/*": ["src/effects/*"],
      "@chart/state/*": ["src/state/*"],
      "@chart/streaming/*": ["src/streaming/*"],
      "@chart/types/*": ["src/types/*"],
      "@chart/utils/*": ["src/utils/*"],
      "@chart/widget/*": ["src/widget/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests", "**/*.test.ts", "**/*.spec.ts"]
}
